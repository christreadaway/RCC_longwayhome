{
  "name": "the-long-way-home",
  "version": "1.0.0",
  "description": "The Long Way Home - Educational Oregon Trail game for Catholic classrooms",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npx vite --host",
    "dev:server": "node server/index.js",
    "build": "cd client && npx vite build",
    "start": "node server/index.js",
    "preview": "cd client && npx vite preview"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
